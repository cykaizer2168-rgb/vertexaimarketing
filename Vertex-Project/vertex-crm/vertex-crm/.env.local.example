# ─── NextAuth (Google OAuth) ─────────────────────────────────────────────────
# Go to: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID → Web Application
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
#                         + https://yourdomain.com/api/auth/callback/google
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-generate-with-openssl-rand-base64-32

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Google APIs ─────────────────────────────────────────────────────────────
# Scopes needed in Google Cloud Console:
#   - Gmail API: https://mail.google.com/
#   - Google Calendar API: https://www.googleapis.com/auth/calendar
#   - Google Sheets API: https://www.googleapis.com/auth/spreadsheets

# Your Vertex AI Marketing Google Sheet (CRM)
GOOGLE_SHEET_ID=1i_fOiBvvMywjgecXOwXisO5Cge8D3V-k8hvhfR7djt4
GOOGLE_SHEET_LEADS_TAB=Leads
GOOGLE_SHEET_SCOPING_TAB=Scoping Calls
GOOGLE_SHEET_CHAT_LOGS_TAB=Chat Logs

# Google Calendar ID (usually your email, or a dedicated CRM calendar)
GOOGLE_CALENDAR_ID=primary

# ─── n8n Webhook ─────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://n8n.srv1356414.hstgr.cloud/webhook/vertex
N8N_API_KEY=your-n8n-api-key
N8N_WORKFLOW_ID=j3hhCaHbY57PGdxJFFXlQ
N8N_BASE_URL=https://n8n.srv1356414.hstgr.cloud/api/v1

# ─── n8n → CRM auth ──────────────────────────────────────────────────────────
# Shared secret: n8n sends this as x-api-key when reading CPL thresholds.
# Generate with: openssl rand -hex 16
# Must match CRM_N8N_SECRET set in n8n's environment variables.
CRM_N8N_SECRET=your-32-char-hex-secret

# ─── Vertex AI / OpenAI (AI Scoring) ─────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ─── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Vertex AI Marketing
NEXT_PUBLIC_ADMIN_EMAIL=angelo@vertexaimarketing.cloud
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link
